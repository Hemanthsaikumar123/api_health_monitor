<section class="card">
  <div class="card-header">
    <h1 class="page-title">Health Checks: <%= @api.name %></h1>
    <%= link_to "Back", apis_path, class: "btn" %>
  </div>

  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Status</th>
          <th>Response Time</th>
          <th>Status Code</th>
          <th>Checked At</th>
        </tr>
      </thead>
      <tbody>
        <% @health_checks.each do |check| %>
          <tr>
            <td>
              <% if check.status == "up" %>
                <span class="status-badge status-up">● UP</span>
              <% else %>
                <span class="status-badge status-down">● DOWN</span>
              <% end %>
            </td>
            <td><%= check.response_time&.round(2) || "-" %> s</td>
            <td><%= check.status_code || "-" %></td>
            <td><%= check.checked_at.strftime("%d %b %Y %I:%M %p") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>